// ─── Sección: Flujo por Empresa ───────────────────────────────────────────────
function FlujoEmpresas() {
  const [emp, setEmp] = useState("Mediterra");
  const [vista, setVista] = useState("tabla");
  const co = COMPANIES_DATA[emp];
  const meta = META[emp] || {emoji:"🏢",color:C.blue};
  const egr = co.months.map((m,i) => co.ing[i] - co.flujo[i]);

  const totalIng   = co.ing.reduce((a,b)=>a+b,0);
  const totalFlujo = co.flujo.reduce((a,b)=>a+b,0);
  const saldoFinal = co.acum[co.acum.length-1];

  // Agrupación por temporada
  const byTem = useMemo(()=>{
    const map={};
    co.months.forEach((m,i)=>{
      const [mes,yr]=m.split("-");
      const mi=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"].indexOf(mes);
      const t=mi>=6?`T${yr}/${String(Number(yr)+1).slice(-2)}`:`T${String(Number(yr)-1).slice(-2)}/${yr}`;
      if(!map[t]) map[t]={ing:0,egr:0,flujo:0};
      map[t].ing+=co.ing[i]; map[t].egr+=egr[i]; map[t].flujo+=co.flujo[i];
    });
    return Object.entries(map);
  },[emp]);

  return (
    <div style={{display:"flex",flexDirection:"column",gap:14}}>
      {/* Selector empresa */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
        {Object.keys(COMPANIES_DATA).map(n=>{
          const m=META[n]||{};
          return(
            <button key={n} onClick={()=>setEmp(n)}
              style={{padding:"6px 11px",borderRadius:8,cursor:"pointer",fontSize:11,fontWeight:600,
                border:`1px solid ${emp===n?(m.color||C.blue):C.border}`,
                background:emp===n?`${m.color||C.blue}22`:"transparent",
                color:emp===n?(m.color||C.blue):C.muted}}>
              {m.emoji} {n}
            </button>
          );
        })}
      </div>

      {/* Header empresa */}
      <div style={{background:`${meta.color}12`,border:`1px solid ${meta.color}44`,
        borderRadius:12,padding:"16px 18px",display:"flex",alignItems:"center",gap:14,flexWrap:"wrap"}}>
        <span style={{fontSize:30}}>{meta.emoji}</span>
        <div style={{flex:1}}>
          <div style={{fontSize:15,fontWeight:900,color:C.text}}>{emp}</div>
          <div style={{fontSize:11,color:C.muted}}>{meta.desc}</div>
        </div>
        {[
          {l:"Saldo Inicial", v:co.saldo_ini, c:C.blue},
          {l:"Ingresos 24m",  v:totalIng,     c:C.green},
          {l:"Flujo Neto 24m",v:totalFlujo,   c:colorFlujo(totalFlujo)},
          {l:"Saldo Final",   v:saldoFinal,   c:colorFlujo(saldoFinal)},
        ].map(k=>(
          <div key={k.l} style={{textAlign:"right"}}>
            <div style={{fontSize:9,color:C.muted,textTransform:"uppercase",letterSpacing:"0.5px"}}>{k.l}</div>
            <div style={{fontSize:13,fontWeight:800,color:k.c}}>{$$(k.v)}</div>
          </div>
        ))}
      </div>

      {/* Sub-tabs */}
      <div style={{display:"flex",gap:6}}>
        {[["tabla","📋 Tabla"],["grafico","📊 Gráfico"],["temporada","📆 Temporadas"]].map(([id,lbl])=>(
          <Tab key={id} id={id} active={vista===id} onClick={setVista} color={meta.color}>{lbl}</Tab>
        ))}
      </div>

      {/* TABLA */}
      {vista==="tabla"&&(
        <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
              <thead>
                <tr style={{background:"rgba(255,255,255,0.04)"}}>
                  {["Mes","Ingresos","Egresos","Flujo Neto","Saldo Acumulado"].map(h=>(
                    <th key={h} style={{padding:"9px 14px",fontWeight:600,fontSize:11,color:C.muted,
                      textTransform:"uppercase",letterSpacing:"0.5px",
                      borderBottom:`1px solid ${C.border}`,textAlign:h==="Mes"?"left":"right",whiteSpace:"nowrap"}}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {co.months.map((m,i)=>(
                  <tr key={i} style={{borderBottom:`1px solid ${C.border}22`,
                    background:co.flujo[i]>0?`${meta.color}08`:i%2===0?"transparent":"rgba(255,255,255,0.01)"}}>
                    <td style={{padding:"9px 14px",fontWeight:600,color:C.text}}>{m}</td>
                    <td style={{padding:"9px 14px",textAlign:"right",color:co.ing[i]>0?C.green:C.muted}}>{co.ing[i]>0?$$(co.ing[i]):"—"}</td>
                    <td style={{padding:"9px 14px",textAlign:"right",color:egr[i]>0?C.red:C.muted}}>{egr[i]>0?$$(egr[i]):"—"}</td>
                    <td style={{padding:"9px 14px",textAlign:"right",fontWeight:700,color:colorFlujo(co.flujo[i])}}>{$$(co.flujo[i])}</td>
                    <td style={{padding:"9px 14px",textAlign:"right",fontWeight:600,color:colorFlujo(co.acum[i])}}>{$$(co.acum[i])}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* GRÁFICO */}
      {vista==="grafico"&&(
        <div style={{display:"flex",flexDirection:"column",gap:14}}>
          <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"16px 18px"}}>
            <div style={{fontSize:11,fontWeight:700,color:C.muted,textTransform:"uppercase",letterSpacing:"0.8px",marginBottom:12}}>Ingresos vs Egresos</div>
            <BarChart months={co.months} ing={co.ing} egr={egr}/>
          </div>
          <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"16px 18px"}}>
            <div style={{fontSize:11,fontWeight:700,color:C.muted,textTransform:"uppercase",letterSpacing:"0.8px",marginBottom:12}}>Saldo Acumulado</div>
            <LineChart months={co.months} values={co.acum} color={meta.color}/>
          </div>
        </div>
      )}

      {/* TEMPORADAS */}
      {vista==="temporada"&&(
        <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
          {byTem.map(([t,d])=>(
            <div key={t} style={{flex:1,minWidth:150,background:C.card,border:`1px solid ${C.border}`,borderRadius:12,padding:"14px 16px"}}>
              <div style={{fontSize:13,fontWeight:800,color:meta.color,marginBottom:10}}>{t}</div>
              {[{l:"Ingresos",v:d.ing,c:C.green},{l:"Egresos",v:d.egr,c:C.red},{l:"Flujo Neto",v:d.flujo,c:colorFlujo(d.flujo)}].map(r=>(
                <div key={r.l} style={{display:"flex",justifyContent:"space-between",marginBottom:6,fontSize:12}}>
                  <span style={{color:C.muted}}>{r.l}</span>
                  <span style={{fontWeight:700,color:r.c}}>{$$(r.v)}</span>
                </div>
              ))}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

