// ─── Sección: Créditos ────────────────────────────────────────────────────────
function Creditos() {
  const [filtroEmp, setFiltroEmp] = useState("Todas");
  const [busq, setBusq] = useState("");
  const empresas = ["Todas", ...Array.from(new Set(CREDITOS.map(c=>c.empresa))).sort()];

  const filtered = CREDITOS.filter(c => {
    if (filtroEmp!=="Todas"&&c.empresa!==filtroEmp) return false;
    if (busq&&![c.empresa,c.acreedor].some(s=>s.toLowerCase().includes(busq.toLowerCase()))) return false;
    return true;
  });

  const deudaEmp = {};
  CREDITOS.forEach(c=>{
    if(!deudaEmp[c.empresa]) deudaEmp[c.empresa]={monto:0,n:0};
