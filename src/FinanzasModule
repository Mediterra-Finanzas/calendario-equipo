// ─── Helpers ──────────────────────────────────────────────────────────────────
const $$ = n => {
  if (n == null) return "—";
  const abs = Math.abs(n), s = n < 0 ? "-" : "";
  if (abs >= 1_000_000) return `${s}$${(abs/1e6).toFixed(2)}M`;
  if (abs >= 1_000)     return `${s}$${(abs/1e3).toFixed(0)}K`;
  return `${s}$${abs.toLocaleString()}`;
};
const fmtDate = s => {
  if (!s) return "—";
  try { const d = new Date(s); return `${String(d.getDate()).padStart(2,"0")}/${String(d.getMonth()+1).padStart(2,"0")}/${d.getFullYear()}`; }
  catch { return s.slice(0,10); }
};
const colorFlujo = v => v >= 0 ? C.green : C.red;

// ─── Mini componentes ─────────────────────────────────────────────────────────
function KPI({ label, value, color }) {
  return (
    <div style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:10, padding:"12px 16px" }}>
      <div style={{ fontSize:10, color:C.muted, textTransform:"uppercase", letterSpacing:"0.5px", marginBottom:4 }}>{label}</div>
      <div style={{ fontSize:18, fontWeight:800, color }}>{value}</div>
    </div>
  );
}

function Sparkline({ data, color, w=100, h=28 }) {
  const vals = data.filter(v => v != null);
  if (vals.length < 2) return null;
  const min=Math.min(...vals), max=Math.max(...vals), range=max-min||1;
  const pts = vals.map((v,i) => `${(i/(vals.length-1))*w},${h-((v-min)/range)*(h-4)-2}`).join(" ");
  const [lx,ly] = [w, h-((vals[vals.length-1]-min)/range)*(h-4)-2];
  return (
    <svg width={w} height={h} style={{overflow:"visible",flexShrink:0}}>
      <polyline points={pts} fill="none" stroke={color} strokeWidth={1.5} strokeLinejoin="round"/>
      <circle cx={lx} cy={ly} r={2.5} fill={color}/>
    </svg>
  );
}

function LineChart({ months, values, color=C.blue, h=88 }) {
  const W=460, pad={l:52,r:8,t:8,b:20};
  const iw=W-pad.l-pad.r, ih=h-pad.t-pad.b;
  const min=Math.min(...values), max=Math.max(...values), range=max-min||1;
  const tx=(i)=>pad.l+(i/(values.length-1))*iw;
  const ty=(v)=>pad.t+ih-((v-min)/range)*ih;
  const pts=values.map((v,i)=>[tx(i),ty(v)]);
  const poly=pts.map(([x,y])=>`${x},${y}`).join(" ");
  const area=`M${pts[0][0]},${h-pad.b} `+pts.map(([x,y])=>`L${x},${y}`).join(" ")+` L${pts[pts.length-1][0]},${h-pad.b} Z`;
  const zy=ty(0);
  return (
    <svg width="100%" viewBox={`0 0 ${W} ${h}`} style={{display:"block"}}>
      <defs><linearGradient id="lg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stopColor={color} stopOpacity="0.2"/>
        <stop offset="100%" stopColor={color} stopOpacity="0.02"/>
      </linearGradient></defs>
      <line x1={pad.l} x2={W-pad.r} y1={zy} y2={zy} stroke={C.border} strokeWidth={1} strokeDasharray="3,3"/>
      <path d={area} fill="url(#lg)"/>
      <polyline points={poly} fill="none" stroke={color} strokeWidth={2} strokeLinejoin="round"/>
      {pts.map(([x,y],i) => {
        const isLast=i===pts.length-1;
        const isPeak=i>0&&i<pts.length-1&&values[i]>values[i-1]&&values[i]>values[i+1];
        const isTrough=i>0&&i<pts.length-1&&values[i]<values[i-1]&&values[i]<values[i+1];
        if (!isLast&&!isPeak&&!isTrough) return null;
        return <circle key={i} cx={x} cy={y} r={isLast?3.5:2.5} fill={colorFlujo(values[i])}/>;
      })}
      {months.map((m,i) => {
        if (i%4!==0&&i!==months.length-1) return null;
        return <text key={i} x={tx(i)} y={h-2} textAnchor="middle" fontSize={7.5} fill={C.muted}>{m}</text>;
      })}
      {[0,0.5,1].map(p => (
        <text key={p} x={pad.l-4} y={pad.t+ih-p*ih+3} textAnchor="end" fontSize={7} fill={C.muted}>
          {$$(Math.round(min+p*range))}
        </text>
      ))}
    </svg>
  );
}

function BarChart({ months, ing, egr, h=72 }) {
  const maxV=Math.max(...ing,...egr,1);
  return (
    <div style={{overflowX:"auto"}}>
      <div style={{minWidth:months.length*42,display:"flex",flexDirection:"column",gap:2}}>
        <div style={{display:"flex",alignItems:"flex-end",gap:2,height:h}}>
          {months.map((m,i)=>(
            <div key={i} style={{flex:1,display:"flex",gap:1,alignItems:"flex-end",justifyContent:"center",minWidth:36}}
              title={`${m}\nIng: ${$$(ing[i]||0)} | Egr: ${$$(egr[i]||0)}`}>
              <div style={{width:"45%",height:Math.max(1,(ing[i]||0)/maxV*(h-4)),background:C.green,borderRadius:"2px 2px 0 0",opacity:0.8}}/>
              <div style={{width:"45%",height:Math.max(1,(egr[i]||0)/maxV*(h-4)),background:C.red,borderRadius:"2px 2px 0 0",opacity:0.6}}/>
            </div>
          ))}
        </div>
        <div style={{display:"flex",gap:2}}>
          {months.map((m,i)=>{
            const f=(ing[i]||0)-(egr[i]||0);
            return <div key={i} style={{flex:1,minWidth:36,textAlign:"center",fontSize:8.5,color:colorFlujo(f),fontWeight:f!==0?700:400}}>{m.slice(0,3)}</div>;
          })}
        </div>
      </div>
      <div style={{display:"flex",gap:14,marginTop:6,fontSize:10.5,color:C.muted}}>
        <span>🟢 Ingresos</span><span>🔴 Egresos</span>
      </div>
    </div>
  );
}

