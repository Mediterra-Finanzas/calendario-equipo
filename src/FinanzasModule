                  <td style={{padding:"9px 14px",fontWeight:600,color:C.text}}>{q}</td>
                  <td style={{padding:"9px 14px",textAlign:"right",color:C.yellow,fontWeight:600}}>{$$(CRED_TRIM.pagos[i])}</td>
                  <td style={{padding:"9px 14px",textAlign:"right",fontWeight:700,color:C.red}}>{$$(CRED_TRIM.saldos[i])}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Filtros */}
      <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
        <input value={busq} onChange={e=>setBusq(e.target.value)} placeholder="🔍 Buscar…"
          style={{padding:"7px 12px",background:C.card2,border:`1px solid ${C.border}`,
            borderRadius:8,color:C.text,fontSize:12,outline:"none",flexGrow:1,minWidth:160}}/>
        <select value={filtroEmp} onChange={e=>setFiltroEmp(e.target.value)}
          style={{padding:"7px 12px",background:C.card2,border:`1px solid ${C.border}`,
            borderRadius:8,color:C.text,fontSize:12,outline:"none"}}>
          {empresas.map(e=><option key={e}>{e}</option>)}
        </select>
        <span style={{fontSize:11,color:C.muted}}>{filtered.length} créditos</span>
      </div>

      {/* Tabla créditos */}
      <div style={{background:C.card,border:`1px solid ${C.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead>
              <tr style={{background:"rgba(255,255,255,0.04)"}}>
                {["#","Empresa","Acreedor","Tipo","Monto","Cuota","Vencimiento","Tasa"].map(h=>(
                  <th key={h} style={{padding:"8px 12px",fontWeight:600,fontSize:10,color:C.muted,
                    textTransform:"uppercase",letterSpacing:"0.5px",borderBottom:`1px solid ${C.border}`,
                    textAlign:["Monto","Cuota","Tasa"].includes(h)?"right":"left",whiteSpace:"nowrap"}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {filtered.map(c=>{
                const vencProx = new Date(c.f_venc)<=new Date("2026-12-31");
                const m=META[c.empresa]||{emoji:"🏢",color:C.blue};
                return(
                  <tr key={c.n} style={{borderBottom:`1px solid ${C.border}22`,
                    background:vencProx?"#e3b34108":"transparent"}}>
                    <td style={{padding:"8px 12px",color:C.muted,fontWeight:600}}>{c.n}</td>
                    <td style={{padding:"8px 12px",fontWeight:600,color:m.color,whiteSpace:"nowrap"}}>{m.emoji} {c.empresa}</td>
                    <td style={{padding:"8px 12px",color:C.text}}>{c.acreedor}</td>
                    <td style={{padding:"8px 12px"}}>
                      <span style={{fontSize:10,padding:"2px 7px",borderRadius:20,
                        background:C.card2,border:`1px solid ${C.border}`,color:C.muted,whiteSpace:"nowrap"}}>
                        {c.tipo_cr}
                      </span>
                    </td>
                    <td style={{padding:"8px 12px",textAlign:"right",fontWeight:700,color:C.red}}>{$$(c.monto)}</td>
                    <td style={{padding:"8px 12px",textAlign:"right",color:C.yellow}}>{$$(c.cuota)}</td>
                    <td style={{padding:"8px 12px",whiteSpace:"nowrap",color:vencProx?C.orange:C.muted}}>
                      {fmtDate(c.f_venc)}{vencProx&&" ⚠️"}
                    </td>
                    <td style={{padding:"8px 12px",textAlign:"right",color:C.muted}}>
                      {c.tasa?`${(parseFloat(c.tasa)*100).toFixed(1)}%`:"—"}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

// ─── Módulo principal ─────────────────────────────────────────────────────────
const TABS = [
  { id:"dashboard", label:"📊 Dashboard",     comp: Dashboard     },
  { id:"banco",     label:"🏦 Saldo Banco",    comp: SaldoBanco    },
  { id:"flujo",     label:"📈 Flujo Empresas", comp: FlujoEmpresas },
  { id:"resumen",   label:"🗂 Resumen Grupo",  comp: ResumenGrupo  },
  { id:"creditos",  label:"💳 Créditos",       comp: Creditos      },
];

export default function FinanzasModule({ onBack, onLogout }) {
  const [tab, setTab] = useState("dashboard");

  const renderTab = () => {
    switch(tab) {
      case "banco":    return <SaldoBanco/>;
      case "flujo":    return <FlujoEmpresas/>;
      case "resumen":  return <ResumenGrupo/>;
      case "creditos": return <Creditos/>;
      default:         return <Dashboard/>;
    }
  };

  return (
    <div style={{fontFamily:"'IBM Plex Sans','Segoe UI',system-ui,sans-serif",
      color:C.text, minHeight:"100vh", background:C.bg}}>

      {/* Top bar */}
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",
        marginBottom:20,flexWrap:"wrap",gap:8,paddingBottom:16,borderBottom:`1px solid ${C.border}`}}>
        <div style={{display:"flex",alignItems:"center",gap:12}}>
          <button onClick={onBack}
            style={{background:"rgba(255,255,255,0.07)",border:`1px solid ${C.border}`,
              color:C.text,borderRadius:8,padding:"6px 14px",cursor:"pointer",fontSize:12}}>
            ← Hub
          </button>
          <img src="/med.png" alt="Mediterra" style={{height:32,objectFit:"contain"}}
            onError={e=>{e.target.style.display="none";}}/>
          <div>
            <div style={{fontSize:14,fontWeight:900}}>Finanzas · Grupo Mediterra</div>
            <div style={{fontSize:10,color:C.muted}}>Flujo de Caja — Modelo Abril 2026 · USD</div>
          </div>
        </div>
        <button onClick={onLogout}
          style={{background:"#f8514922",border:"none",color:C.red,
            borderRadius:8,padding:"6px 14px",cursor:"pointer",fontSize:12}}>
          Salir
        </button>
      </div>

      {/* Nav */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:20}}>
        {TABS.map(t=>(
          <Tab key={t.id} id={t.id} active={tab===t.id} onClick={setTab}>{t.label}</Tab>
        ))}
      </div>

      {renderTab()}
    </div>
  );
}
